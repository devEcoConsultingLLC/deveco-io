# ===========================================
# CommonPub Reference App — Environment Variables
# ===========================================
# Copy to .env and adjust values as needed.
# These map to Nuxt runtimeConfig (nuxt.config.ts).
# Most values are inherited from the root .env — only override here if needed.

# ---- Nuxt Public Runtime Config ----
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Nuxt Server Runtime Config ----
# Database (inherited from root .env if set)
# DATABASE_URL=postgresql://commonpub:commonpub_dev@localhost:5433/commonpub

# Auth
# AUTH_SECRET=change-me-in-production-min-32-chars
# NUXT_AUTH_ORIGIN=http://localhost:3000

# Redis
# REDIS_URL=redis://localhost:6380

# Meilisearch
# MEILI_URL=http://localhost:7701
# MEILI_MASTER_KEY=commonpub_dev_key

# ---- Email transport ----
# The email adapter defaults to `console` (logs, does not send). To actually
# deliver mail (verification, notifications, contest reminders) set the adapter
# to `resend` (or `smtp`) AND provide credentials. These MUST use the NUXT_
# prefix — Nuxt only maps env overrides for declared runtimeConfig keys, so a
# bare RESEND_API_KEY (no NUXT_ prefix) is silently ignored and mail falls back
# to the console sink even with `emailNotifications` on.
# NUXT_EMAIL_ADAPTER=resend
# NUXT_RESEND_API_KEY=re_...
# NUXT_RESEND_FROM=noreply@deveco.io
# SMTP alternative:
# NUXT_EMAIL_ADAPTER=smtp
# NUXT_SMTP_HOST=smtp.example.com
# NUXT_SMTP_PORT=587
# NUXT_SMTP_USER=
# NUXT_SMTP_PASS=
# NUXT_SMTP_FROM=noreply@deveco.io

# ---- Federation ----
# Enable ActivityPub federation (WebFinger, inbox/outbox, content delivery)
# FEATURE_FEDERATION=true

# Instance domain (used in AP actor URIs — must match your public domain)
# INSTANCE_DOMAIN=deveco.io

# Instance name and description (shown in NodeInfo)
# INSTANCE_NAME=devEco.io
# INSTANCE_DESCRIPTION=Edge AI project sharing and community platform
