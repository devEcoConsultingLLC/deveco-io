# ===========================================
# devEco.io Environment Variables
# Copy to .env and fill in values
# ===========================================

# Database
DATABASE_URL=postgresql://deveco:deveco@localhost:5432/deveco
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=deveco
DATABASE_PASSWORD=deveco
DATABASE_NAME=deveco

# Redis
REDIS_URL=redis://localhost:6379

# Auth (Better Auth)
AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars
AUTH_URL=http://localhost:3000

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# S3-Compatible Storage (MinIO for dev, DO Spaces for prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=deveco
S3_PUBLIC_URL=http://localhost:9000/deveco

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=deveco-master-key

# App
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_API_URL=http://localhost:3001
NODE_ENV=development
